@model AppGambit.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h2 class="text-center">@ViewData["Title"]</h2>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 border-end">
                        <section>
                            <form asp-controller="Account" asp-action="Register" method="post" id="registerForm">
                                <h4>Создать новый аккаунт</h4>
                                <hr />
                                <div asp-validation-summary="All" class="text-danger"></div>
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label"></label>
                                    <input asp-for="Email" class="form-control" id="emailInput" autocomplete="email" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="DisplayName" class="form-label"></label>
                                    <input asp-for="DisplayName" class="form-control" id="displayNameInput" />
                                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label"></label>
                                    <input asp-for="Password" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                    <small class="form-text text-muted">Минимум 6 символов</small>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label"></label>
                                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <button type="submit" class="btn btn-primary w-100" id="registerButton">
                                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true" id="registerSpinner"></span>
                                        Зарегистрироваться
                                    </button>
                                </div>
                            </form>
                        </section>
                    </div>
                    <div class="col-md-6">
                        <section>
                            <h4>Использовать другой сервис</h4>
                            <hr />
                            <p>Вы также можете зарегистрироваться с помощью внешних сервисов.</p>
                            
                            <div class="d-grid gap-2">
                                <a class="btn btn-danger d-flex align-items-center justify-content-center gap-2"
                                   id="googleAuthButton" 
                                   href="@Url.Action("ExternalLogin", "Account", new { provider = "Google", returnurl = ViewData["ReturnUrl"] })">
                                    <i class="bi bi-google"></i>
                                    <span>Продолжить с Google</span>
                                </a>
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/register.js"></script>
} 