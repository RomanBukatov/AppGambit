@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="h3 mb-0">Произошла ошибка</h1>
                </div>
                <div class="card-body">
                    @if (Model.ShowDetailedError)
                    {
                        <div class="alert alert-danger">
                            <h4>Сообщение об ошибке:</h4>
                            <pre class="bg-light p-3 border rounded"><code>@Model.ErrorMessage</code></pre>
                        </div>
                    }
                    else
                    {
                        <p class="lead">При обработке вашего запроса произошла ошибка.</p>
                    }
                    
                    <h4 class="mt-4">Техническая информация:</h4>
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tbody>
                                @if (Model.ShowRequestId)
                                {
                                    <tr>
                                        <th style="width: 200px">ID запроса:</th>
                                        <td><code>@Model.RequestId</code></td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Path))
                                {
                                    <tr>
                                        <th>Путь:</th>
                                        <td><code>@Model.Path</code></td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Query))
                                {
                                    <tr>
                                        <th>Параметры запроса:</th>
                                        <td><code>@Model.Query</code></td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Cookies))
                                {
                                    <tr>
                                        <th>Cookies:</th>
                                        <td><code>@Model.Cookies</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary">Вернуться на главную</a>
                        <a href="/Account/Login" class="btn btn-outline-secondary ms-2">Вернуться на страницу входа</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
